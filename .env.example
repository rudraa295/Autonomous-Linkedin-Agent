# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LinkedIn OAuth2 access token — generated by running linkedin_auth_helper.py in the terminal
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Your LinkedIn person URN (also printed by linkedin_auth_helper.py in the terminal)
LINKEDIN_PERSON_URN=urn:li:person:xxxxxxxxxx

# LinkedIn app credentials — from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
